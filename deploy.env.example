# === Диски: DISK_ИмяШары=UUID ===
# Замени UUID на свои реальные диски.
# Найти UUID: lsblk -o NAME,UUID или sudo blkid
#DISK_ARCHIVE=your-uuid-here-1111-2222-3333-444455556666
#DISK_MEDIA=your-uuid-here-5555-6666-7777-888899990000
#DISK_DATA=your-uuid-here-9999-0000-1111-222233334444

# Настройки Samba
WORKGROUP=WORKGROUP
SERVER_STRING=Docker Samba+NFS (Alpine)
NETBIOS_NAME=dockersamba
GUEST_OK=yes
READ_ONLY=no
FORCE_USER=root
