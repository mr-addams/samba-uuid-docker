# === Disks: DISK_ShareName=UUID ===
# Syntax: DISK_<SHARE_NAME>=<DISK_UUID>
# where <SHARE_NAME> — name to display in Samba/NFS
#       <DISK_UUID> — UUID of block device (not mounted on host)
#
# Examples:
#   DISK_A=abcd1234-5678-90ef-ghij-klmnopqrstuv
#   DISK_B=efgh5678-9012-3456-7890-abcdef123456
#
# ⚠️ IMPORTANT: replace UUID below with your REAL disk UUIDs!
# Find your disk UUID:
#   lsblk -o NAME,UUID
#   or: sudo blkid
#
# Current UUID (26e51b8e-43d5-46f9-ac18-dc298fbeb9a1) is an example/fake UUID.
# Container will not start until you replace it with your real disk UUID.
DISK_ARCHIVE=26e51b8e-43d5-46f9-ac18-dc298fbeb9a1

# Samba configuration
WORKGROUP=WORKGROUP
SERVER_STRING=Docker Samba+NFS (Alpine)
NETBIOS_NAME=dockersamba
GUEST_OK=yes
READ_ONLY=no
FORCE_USER=root

