# === Диски: DISK_ИмяШары=UUID ===
# Синтаксис: DISK_<ИМЯ_ШАРЫ>=<UUID_ДИСКА>
# где <ИМЯ_ШАРЫ> — имя для отображения в Samba/NFS
#     <UUID_ДИСКА> — UUID блочного устройства (не смонтированного на хосте)
#
# Например:
#   DISK_A=abcd1234-5678-90ef-ghij-klmnopqrstuv
#   DISK_B=efgh5678-9012-3456-7890-abcdef123456
#
# ⚠️ ВАЖНО: замени UUID ниже на свои РЕАЛЬНЫЕ диски!
# Найти UUID своего диска:
#   lsblk -o NAME,UUID
#   или: sudo blkid
#
# Текущий UUID (26e51b8e-43d5-46f9-ac18-dc298fbeb9a1) — это пример/фейковый UUID.
# Контейнер не запустится, пока вы не замените его на UUID вашего реального диска.
DISK_ARCHIVE=26e51b8e-43d5-46f9-ac18-dc298fbeb9a1

#Настройки Samba
WORKGROUP=WORKGROUP
SERVER_STRING=Docker Samba+NFS (Alpine)
NETBIOS_NAME=dockersamba
GUEST_OK=yes
READ_ONLY=no
FORCE_USER=root

