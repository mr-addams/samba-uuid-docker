# === Диски: DISK_ИмяШары=UUID ===
#Замени UUID на свои реальные
#DISK_A=abcd1234-5678-90ef-ghij-klmnopqrstuv
#DISK_B=efgh5678-9012-3456-7890-abcdef123456
#DISK_DATA=12345678-1234-1234-1234-123456789abc
#DISK_MEDIA=98765432-4321-4321-4321-cba987654321
# ⚠️ ВАЖНО: замени UUID на свой реальный диск!
# Найти UUID: lsblk -o NAME,UUID или sudo blkid
# Пример ниже — вымышленный (маскированный) для безопасности в репозитории.
DISK_ARCHIVE=36e7b6c6-****-****-bb1d-873615faa1c7

#Настройки Samba
WORKGROUP=WORKGROUP
SERVER_STRING=Docker Samba+NFS (Alpine)
NETBIOS_NAME=dockersamba
GUEST_OK=yes
READ_ONLY=no
FORCE_USER=root

